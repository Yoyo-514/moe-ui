{
  "name": "moe-ui-monorepo",
  "version": "1.0.0",
  "description": "A light anime-inspired Vue 3 component library monorepo.",
  "main": "index.js",
  "scripts": {
    "docs:dev": "pnpm --filter @moe-ui/docs run dev",
    "docs:build": "pnpm --filter @moe-ui/docs run build",
    "test": "pnpm --filter @moe-ui/components run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,less,scss}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify/vue": "^5.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "postcss-color-mix": "^1.1.0",
    "postcss-each": "^1.1.0",
    "postcss-each-variables": "^0.3.0",
    "postcss-for": "^2.1.1",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.2"
  },
  "dependencies": {
    "@moe-ui/hooks": "workspace:*",
    "@moe-ui/theme": "workspace:*",
    "@moe-ui/utils": "workspace:*",
    "lodash-es": "^4.18.1",
    "moe-ui": "workspace:*",
    "vue": "^3.5.35"
  },
  "engines": {
    "node": ">=22"
  }
}
