{
  "name": "moe-cute-ui-monorepo",
  "version": "0.1.0",
  "description": "A cute and light anime-inspired Vue 3 component library monorepo.",
  "main": "index.js",
  "scripts": {
    "docs:dev": "pnpm --filter @moe-ui/docs run dev",
    "docs:build": "pnpm --filter @moe-ui/docs run build",
    "build": "pnpm run build:lib",
    "build:dev": "pnpm run build:lib:dev",
    "build:prod": "pnpm run build:lib",
    "build:lib": "cross-env NODE_ENV=production run-s build:tools build:hooks build:core",
    "build:lib:dev": "cross-env NODE_ENV=development run-s build:tools build:hooks build:core",
    "build:tools": "pnpm --filter @moe-ui-private/vite-plugins run build",
    "build:vite-plugins": "pnpm run build:tools",
    "build:libs": "run-s build:tools build:hooks",
    "build:hooks": "pnpm --filter @moe-ui/hooks run build",
    "generate:components": "pnpm --filter moe-cute-ui run generate:components",
    "build:core": "pnpm --filter moe-cute-ui run build",
    "build:watch": "cross-env NODE_ENV=development pnpm --filter moe-cute-ui run build:watch",
    "pack:check": "pnpm --filter moe-cute-ui exec npm pack --dry-run",
    "test": "cross-env NODE_ENV=test run-s test:components test:utils test:hooks",
    "test:components": "vitest --config vitest.config.ts packages/components --coverage",
    "test:utils": "vitest --config vitest.config.ts packages/utils --coverage",
    "test:hooks": "vitest --config vitest.config.ts packages/hooks --coverage",
    "check": "run-s lint typecheck test",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:check": "run-s check build docs:build pack:check",
    "publish:dry": "run-s release:check publish:dry-run",
    "publish:npm": "run-s release:check publish:npm-only",
    "publish:dry-run": "pnpm --filter moe-cute-ui exec npm publish --dry-run --registry https://registry.npmjs.org",
    "publish:npm-only": "pnpm --filter moe-cute-ui publish --no-git-checks --registry https://registry.npmjs.org"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,less,scss}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@iconify/vue": "^5.0.1",
    "@popperjs/core": "^2.11.8",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.3",
    "@types/shelljs": "^0.10.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/tsconfig": "^0.9.1",
    "async-validator": "^4.2.5",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "npm-run-all": "^4.1.5",
    "postcss-color-mix": "^1.1.0",
    "postcss-each": "^1.1.0",
    "postcss-each-variables": "^0.3.0",
    "postcss-for": "^2.1.1",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "shelljs": "^0.10.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.5"
  },
  "dependencies": {
    "@moe-ui-private/vite-plugins": "workspace:*",
    "@moe-ui/components": "workspace:*",
    "@moe-ui/hooks": "workspace:*",
    "@moe-ui/theme": "workspace:*",
    "@moe-ui/utils": "workspace:*",
    "lodash-es": "catalog:",
    "moe-cute-ui": "workspace:*",
    "vue": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "private": true
}
