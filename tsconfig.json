{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "paths": {
      "@moe-ui/components": ["./packages/components/index.ts"],
      "@moe-ui/constants": ["./packages/constants/index.ts"],
      "@moe-ui/constants/*": ["./packages/constants/*"],
      "@moe-ui/components/*": ["./packages/components/*"],
      "@moe-ui/hooks": ["./packages/hooks/index.ts"],
      "@moe-ui/hooks/*": ["./packages/hooks/*"],
      "@moe-ui/theme": ["./packages/theme/index.scss"],
      "@moe-ui/theme/*": ["./packages/theme/*"],
      "@moe-ui/utils": ["./packages/utils/index.ts"],
      "@moe-ui/utils/*": ["./packages/utils/*"],
      "@moe-ui/test-utils": ["./packages/test-utils/index.ts"],
      "@moe-ui/test-utils/*": ["./packages/test-utils/*"],
      "@moe-ui-private/vite-plugins": ["./libs/vite-plugins/index.ts"],
      "@moe-ui-private/vite-plugins/*": ["./libs/vite-plugins/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "env.d.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "packages/**/*.vue",
    "packages/**/*.d.ts",
    "libs/**/*.ts"
  ]
}
