{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist/types",
    "rootDir": ".."
  },
  "include": [
    "index.ts",
    "component.ts",
    "defaults.ts",
    "make-installer.ts",
    "resolver.ts",
    "style.d.ts",
    "../../env.d.ts",
    "../components/**/*.ts",
    "../components/**/*.vue",
    "../utils/**/*.ts",
    "../hooks/**/*.ts",
    "../locale/**/*.ts",
    "../constants/**/*.ts"
  ],
  "exclude": ["../components/**/*.test.ts", "../components/**/*.test.tsx"]
}
