{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist/types",
    "rootDir": ".."
  },
  "include": [
    "index.ts",
    "components.ts",
    "style.d.ts",
    "../../env.d.ts",
    "../components/**/*.ts",
