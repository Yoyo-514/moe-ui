{
  "name": "moe-cute-ui",
  "version": "0.2.1",
  "description": "A cute and light anime-inspired Vue 3 component library.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yoyo-514/moe-ui",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "dist/umd/index.js",
  "module": "dist/es/index.mjs",
  "unpkg": "dist/umd/index.js",
  "jsdelivr": "dist/umd/index.js",
  "types": "dist/types/core/index.d.ts",
  "style": "dist/index.css",
  "exports": {
    ".": {
      "types": "./dist/types/core/index.d.ts",
      "import": "./dist/es/index.mjs",
      "default": "./dist/es/index.mjs"
    },
    "./style.css": "./dist/index.css",
    "./resolver": {
      "types": "./dist/types/core/resolver.d.ts",
      "import": "./dist/es/resolver.mjs"
    },
    "./es": {
      "types": "./dist/types/core/index.d.ts",
      "import": "./dist/es/index.mjs"
    },
    "./es/components/*": {
      "types": "./dist/types/components/*/index.d.ts",
      "import": "./dist/es/components/*/index.mjs"
    },
    "./es/components/*/style/css": "./dist/es/components/*/style/css.mjs",
    "./theme/*": "./dist/theme/*",
    "./umd": "./dist/umd/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "sideEffects": [
    "*.css",
    "*.scss",
    "dist/**/*.css",
    "dist/es/components/*/style/*",
    "dist/theme/**/*.css"
  ],
  "scripts": {
    "generate:components": "node build/generate-components.mjs",
    "build:es": "vite build -c build/vite.config.es.ts",
    "build:umd": "vite build -c build/vite.config.umd.ts",
    "build:watch": "vite build -c build/vite.config.es.ts --watch",
    "build": "run-s generate:components build:es build:umd build:styles",
    "build:styles": "node build/build-styles.mjs"
  },
  "keywords": [
    "vue",
    "vue3",
    "component-library",
    "moe-cute-ui"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "vue": "catalog:"
  },
  "dependencies": {
    "@iconify/vue": "catalog:",
    "@popperjs/core": "catalog:",
    "async-validator": "catalog:",
    "lodash-es": "catalog:"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "terser": "^5.48.0",
    "vite-plugin-compression2": "^2.5.3"
  }
}
